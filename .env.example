# GitLab Terraform State Registry auth
# - username: typically "gitlab-token"
# - password: GitLab Personal Access Token with access to the Terraform State Registry
TF_HTTP_USERNAME=gitlab-token
TF_HTTP_PASSWORD=

# Cloudflare API access
CLOUDFLARE_API_TOKEN=

# OAuth/OpenID secrets (Cloudflare Access / OAuth proxy, if used)
OPENID_CLIENT_SECRET_CLOUDFLARE=
OPENID_CLIENT_ID_CLOUDFLARE=

# Kubernetes access for shared infra cluster (used by some modules)
INFRA_K8S_HOST=
INFRA_K8S_CERTIFICATE=
INFRA_K8S_TOKEN=

# Kubernetes access for prod-0 cluster (used by some modules)
PROD-0_K8S_HOST=
PROD-0_K8S_CERTIFICATE=
PROD-0_K8S_TOKEN=
